{
  "name": "proplist-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint ./src ./app",
    "format": "biome format --write ./src ./app",
    "check": "biome check --write ./src ./app",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@react-email/components": "^0.0.22",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.43.0",
    "antd": "^5.17.0",
    "next": "14.2.3",
    "next-intl": "^3.14.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^3.2.0",
    "stripe": "^15.7.0",
    "swr": "^2.2.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write"
    ]
  }
}
